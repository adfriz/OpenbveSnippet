<?xml version="1.0" encoding="UTF-8" ?>
<NotepadPlus>
    <AutoComplete language="CSV">
        <Environment ignoreCase="yes" startFunc="," stopFunc="" paramSeparator="," terminal="" additionalWordChar="_." />
        
        <KeyWord name="CreateMeshBuilder" func="yes">
            <Overload retVal="Marks beginning of new section of faces." />
        </KeyWord>
        <KeyWord name="AddVertex" func="yes">
            <Overload retVal="Creates new vertex with position and optional normals.">
                <Param name="vX" /><Param name="vY" /><Param name="vZ" />
                <Param name="nX" /><Param name="nY" /><Param name="nZ" />
            </Overload>
        </KeyWord>
        <KeyWord name="AddFace" func="yes">
            <Overload retVal="Creates face from vertex indices (clockwise order).">
                <Param name="v1" /><Param name="v2" /><Param name="v3" /><Param name="v4" />
            </Overload>
        </KeyWord>
        <KeyWord name="AddFace2" func="yes">
            <Overload retVal="Creates double-sided face.">
                <Param name="v1" /><Param name="v2" /><Param name="v3" /><Param name="v4" />
            </Overload>
        </KeyWord>
        <KeyWord name="Cube" func="yes">
            <Overload retVal="Creates centered cube.">
                <Param name="HalfWidth" /><Param name="HalfHeight" /><Param name="HalfDepth" />
            </Overload>
        </KeyWord>
        <KeyWord name="Cylinder" func="yes">
            <Overload retVal="Creates frustum/prism.">
                <Param name="n" /><Param name="UpperRadius" /><Param name="LowerRadius" /><Param name="Height" />
            </Overload>
        </KeyWord>
        <KeyWord name="Translate" func="yes">
            <Overload retVal="Translates current section vertices.">
                <Param name="X" /><Param name="Y" /><Param name="Z" />
            </Overload>
        </KeyWord>
        <KeyWord name="TranslateAll" func="yes">
            <Overload retVal="Translates all vertices in object.">
                <Param name="X" /><Param name="Y" /><Param name="Z" />
            </Overload>
        </KeyWord>
        <KeyWord name="Scale" func="yes">
            <Overload retVal="Scales current section vertices.">
                <Param name="X" /><Param name="Y" /><Param name="Z" />
            </Overload>
        </KeyWord>
        <KeyWord name="ScaleAll" func="yes">
            <Overload retVal="Scales all vertices in object.">
                <Param name="X" /><Param name="Y" /><Param name="Z" />
            </Overload>
        </KeyWord>
        <KeyWord name="Rotate" func="yes">
            <Overload retVal="Rotates current section vertices around axis by Angle degrees.">
                <Param name="X" /><Param name="Y" /><Param name="Z" /><Param name="Angle" />
            </Overload>
        </KeyWord>
        <KeyWord name="RotateAll" func="yes">
            <Overload retVal="Rotates all vertices in object around axis by Angle degrees.">
                <Param name="X" /><Param name="Y" /><Param name="Z" /><Param name="Angle" />
            </Optimize>
        </KeyWord>
        <KeyWord name="Mirror" func="yes">
            <Overload retVal="Mirrors current section vertices (1=true, 0=false).">
                <Param name="X" /><Param name="Y" /><Param name="Z" />
            </Overload>
        </KeyWord>
        <KeyWord name="MirrorAll" func="yes">
            <Overload retVal="Mirrors all vertices in object (1=true, 0=false).">
                <Param name="X" /><Param name="Y" /><Param name="Z" />
            </Overload>
        </KeyWord>
        <KeyWord name="Shear" func="yes">
            <Overload retVal="Shear mapping for current section.">
                <Param name="dX" /><Param name="dY" /><Param name="dZ" />
                <Param name="sX" /><Param name="sY" /><Param name="sZ" /><Param name="r" />
            </Overload>
        </KeyWord>
        <KeyWord name="ShearAll" func="yes">
            <Overload retVal="Shear mapping for all vertices.">
                <Param name="dX" /><Param name="dY" /><Param name="dZ" />
                <Param name="sX" /><Param name="sY" /><Param name="sZ" /><Param name="r" />
            </Overload>
        </KeyWord>
        <KeyWord name="SetColor" func="yes">
            <Overload retVal="Sets vertex color (0-255).">
                <Param name="Red" /><Param name="Green" /><Param name="Blue" /><Param name="Alpha" />
            </Overload>
        </KeyWord>
        <KeyWord name="SetColorAll" func="yes">
            <Overload retVal="Sets color for ALL faces in object.">
                <Param name="Red" /><Param name="Green" /><Param name="Blue" /><Param name="Alpha" />
            </Overload>
        </KeyWord>
        <KeyWord name="SetEmissiveColor" func="yes">
            <Overload retVal="Sets emissive color (ignores lighting).">
                <Param name="Red" /><Param name="Green" /><Param name="Blue" />
            </Overload>
        </KeyWord>
        <KeyWord name="SetEmissiveColorAll" func="yes">
            <Overload retVal="Sets emissive color for ALL faces in object.">
                <Param name="Red" /><Param name="Green" /><Param name="Blue" />
            </Overload>
        </KeyWord>
        <KeyWord name="SetBlendMode" func="yes">
            <Overload retVal="Sets blend mode and glow attenuation.">
                <Param name="Mode (Normal/Additive)" /><Param name="GlowHalfDistance" /><Param name="Exponent (2/4)" />
            </Overload>
        </KeyWord>
        <KeyWord name="SetWrapMode" func="yes">
            <Overload retVal="Texture tiling behavior.">
                <Param name="Mode (Repeat/Clamp)" />
            </Overload>
        </KeyWord>
        <KeyWord name="LoadTexture" func="yes">
            <Overload retVal="Loads texture for current section.">
                <Param name="DaytimeTexture" /><Param name="NighttimeTexture" />
            </Overload>
        </KeyWord>
        <KeyWord name="SetDecalTransparentColor" func="yes">
            <Overload retVal="Transparency color key for textures.">
                <Param name="Red" /><Param name="Green" /><Param name="Blue" />
            </Overload>
        </KeyWord>
        <KeyWord name="EnableCrossfading" func="yes">
            <Overload retVal="Controls blending between day and night textures.">
                <Param name="true/false" />
            </Overload>
        </KeyWord>
        <KeyWord name="SetTextureCoordinates" func="yes">
            <Overload retVal="Associates texture UV (X, Y) to vertex index.">
                <Param name="VertexIndex" /><Param name="X" /><Param name="Y" />
            </Overload>
        </KeyWord>
    </AutoComplete>
</NotepadPlus>